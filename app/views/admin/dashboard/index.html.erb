<% content_for :title, t("admin.dashboard.title") %>

<div class="row">
  <div class="col-md-3 mb-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <i class="fas fa-box fa-2x text-primary mb-3"></i>
        <h5 class="card-title"><%= t("admin.dashboard.stats.products") %></h5>
        <h3 class="text-primary"><%= @stats[:total_products] %></h3>
        <small class="text-muted"><%= t("admin.dashboard.stats.active") %>: <%= @stats[:active_products] %></small>
        <div class="mt-3">
          <%= link_to t("admin.dashboard.actions.manage"), admin_products_path, class: "btn btn-primary btn-sm" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <i class="fas fa-tags fa-2x text-success mb-3"></i>
        <h5 class="card-title"><%= t("admin.dashboard.stats.categories") %></h5>
        <h3 class="text-success"><%= @stats[:total_categories] %></h3>
        <small class="text-muted"><%= t("admin.dashboard.stats.active") %>: <%= @stats[:active_categories] %></small>
        <div class="mt-3">
          <%= link_to t("admin.dashboard.actions.manage"), admin_categories_path, class: "btn btn-success btn-sm" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <i class="fas fa-star fa-2x text-warning mb-3"></i>
        <h5 class="card-title"><%= t("admin.dashboard.stats.featured_products") %></h5>
        <h3 class="text-warning"><%= @stats[:featured_products] %></h3>
        <small class="text-muted"><%= t("admin.dashboard.stats.out_of_active", total: @stats[:active_products]) %></small>
        <div class="mt-3">
          <%= link_to t("admin.dashboard.actions.view"), admin_products_path(featured: "yes"), class: "btn btn-warning btn-sm" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <i class="fas fa-exclamation-triangle fa-2x text-danger mb-3"></i>
        <h5 class="card-title"><%= t("admin.dashboard.stats.low_stock") %></h5>
        <h3 class="text-danger"><%= @stats[:low_stock_products] %></h3>
        <small class="text-muted"><%= t("admin.dashboard.stats.need_attention") %></small>
        <div class="mt-3">
          <%= link_to t("admin.dashboard.actions.view"), admin_products_path(stock_status: "low_stock"), class: "btn btn-danger btn-sm" %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h6 class="card-title mb-0"><%= t("admin.dashboard.recent_products.title") %></h6>
      </div>
      <div class="card-body">
        <% if @recent_products.any? %>
          <% @recent_products.each do |product| %>
            <div class="d-flex align-items-center mb-3">
              <div class="me-3">
                <div class="product-image-thumb bg-light d-flex align-items-center justify-content-center">
                  <i class="fas fa-image text-muted"></i>
                </div>
              </div>
              <div class="flex-grow-1">
                <h6 class="mb-1"><%= product.name %></h6>
                <small class="text-muted">
                  <%= product.brand&.name %>
                  <% if product.categories.any? %>
                    • <%= product.categories.first.name %>
                  <% end %>
                </small>
                <div class="mt-1">
                  <span class="badge <%= product.is_active? ? 'bg-success' : 'bg-secondary' %>">
                    <%= product.is_active? ? t("admin.dashboard.stats.active") : t("admin.dashboard.stats.inactive") %>
                  </span>
                  <% if product.is_featured? %>
                    <span class="badge bg-warning"><%= t("admin.dashboard.stats.featured") %></span>
                  <% end %>
                </div>
              </div>
              <div class="text-end">
                <div class="fw-bold"><%= number_to_currency(product.current_price) %></div>
                <small class="text-muted"><%= t("admin.dashboard.recent_products.stock") %>: <%= product.stock_quantity %></small>
              </div>
            </div>
          <% end %>
          <div class="text-center mt-3">
            <%= link_to t("admin.dashboard.recent_products.view_all"), admin_products_path, class: "btn btn-outline-primary btn-sm" %>
          </div>
        <% else %>
          <div class="text-center text-muted py-4">
            <i class="fas fa-box fa-3x mb-3"></i>
            <div><%= t("admin.dashboard.no_data.no_products") %></div>
            <%= link_to t("admin.dashboard.no_data.add_first_product"), new_admin_product_path, class: "btn btn-primary btn-sm mt-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h6 class="card-title mb-0"><%= t("admin.dashboard.category_overview.title") %></h6>
      </div>
      <div class="card-body">
        <% if @recent_categories.any? %>
          <% @recent_categories.each do |category| %>
            <div class="d-flex justify-content-between align-items-center mb-2">
              <div>
                <span class="fw-medium"><%= category.name %></span>
                <% if category.parent %>
                  <small class="text-muted">(<%= category.parent.name %>)</small>
                <% end %>
              </div>
              <div class="text-end">
                <span class="badge bg-primary"><%= category.products.count %> <%= t("admin.dashboard.category_overview.products") %></span>
                <span class="badge <%= category.is_active? ? 'bg-success' : 'bg-secondary' %>">
                  <%= category.is_active? ? t("admin.dashboard.stats.active") : t("admin.dashboard.stats.inactive") %>
                </span>
              </div>
            </div>
          <% end %>
          <div class="text-center mt-3">
            <%= link_to t("admin.dashboard.category_overview.manage"), admin_categories_path, class: "btn btn-outline-success btn-sm" %>
          </div>
        <% else %>
          <div class="text-center text-muted py-4">
            <i class="fas fa-tags fa-3x mb-3"></i>
            <div><%= t("admin.dashboard.no_data.no_categories") %></div>
            <%= link_to t("admin.dashboard.no_data.add_first_category"), new_admin_category_path, class: "btn btn-success btn-sm mt-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Low Stock Products Section -->
<% if @low_stock_products.any? %>
  <div class="row mt-4">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6>
            <i class="fas fa-exclamation-triangle me-2"></i>
            <%= t("admin.dashboard.low_stock_section.title") %>
          </h6>
          <%= link_to t("admin.dashboard.low_stock_section.view_all"), admin_products_path(stock_status: "low_stock"), class: "btn btn-outline-danger btn-sm" %>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-sm">
              <thead>
                <tr>
                  <th><%= t("admin.dashboard.low_stock_section.product") %></th>
                  <th><%= t("admin.dashboard.low_stock_section.brand") %></th>
                  <th><%= t("admin.dashboard.low_stock_section.current_stock") %></th>
                  <th><%= t("admin.dashboard.low_stock_section.threshold") %></th>
                  <th><%= t("admin.dashboard.low_stock_section.actions") %></th>
                </tr>
              </thead>
              <tbody>
                <% @low_stock_products.each do |product| %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <div class="me-3">
                          <div class="product-image-thumb bg-light d-flex align-items-center justify-content-center">
                            <i class="fas fa-image text-muted"></i>
                          </div>
                        </div>
                        <div>
                          <%= link_to product.name, admin_product_path(product), class: "text-decoration-none fw-medium" %>
                          <div class="small text-muted"><%= t("admin.products.index.table.sku") %>: <%= product.sku %></div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <% if product.brand %>
                        <span class="badge bg-info"><%= product.brand.name %></span>
                      <% else %>
                        <span class="text-muted">-</span>
                      <% end %>
                    </td>
                    <td>
                      <span class="badge bg-warning text-dark">
                        <%= product.stock_quantity %> <%= t("admin.dashboard.low_stock_section.units") %>
                      </span>
                    </td>
                    <td>
                      <span class="text-muted"><%= Settings.business.low_stock_threshold %></span>
                    </td>
                    <td>
                      <%= link_to t("admin.dashboard.low_stock_section.restock"), edit_admin_product_path(product), class: "btn btn-outline-success btn-sm" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
